{
  "name": "moth-light",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "MOTH//LAMP — a mobile-first side-scrolling moth shooter for the Base App",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sprites.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"*.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/tests/unit",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --pretty false",
    "generate:assets": "node scripts/generate-assets.mjs && node scripts/generate-sprites.mjs",
    "generate:sprites": "node scripts/generate-sprites.mjs"
  },
  "dependencies": {
    "@base-org/account": "^2.5.7",
    "@tanstack/react-query": "^5.101.2",
    "phaser": "3.87.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "viem": "^2.55.0",
    "wagmi": "^3.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
