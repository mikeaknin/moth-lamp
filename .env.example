# MOTH//LAMP environment variables
# Copy to .env.local for local overrides. Never commit secrets.

# Use Base Sepolia for any wallet development (default true)
VITE_USE_TESTNET=true

# Optional custom RPCs
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org
VITE_BASE_RPC=https://mainnet.base.org

# Builder Code from base.dev → Settings → Builder Codes
# Only needed if you send onchain transactions outside the Base App browser
# (Base App auto-appends builder codes for registered apps)
VITE_BUILDER_CODE=

# Optional WalletConnect cloud project id (not required for Base Account injected flow)
VITE_WALLETCONNECT_PROJECT_ID=
